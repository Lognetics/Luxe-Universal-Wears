# Luxe Universal Wears — environment variables
# Copy to .env.local and fill in. .env.local is gitignored.
# The public site runs WITHOUT these (catalog falls back to local JSON).

# Public — needed by the site + admin panel (also add these two to Vercel):
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon public key>

# Only needed locally for one-time DB setup (scripts/db-setup.mjs):
SUPABASE_DB_URL=postgresql://postgres:<password>@<host>:5432/postgres
ADMIN_EMAILS=admin@example.com
